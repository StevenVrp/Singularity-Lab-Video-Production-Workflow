    <script>
        // The JavaScript functionality remains exactly the same, as it contains no user-visible text.
        document.addEventListener('DOMContentLoaded', function() {
            const nodes = document.querySelectorAll('.node');
            const panels = document.querySelectorAll('.details-panel');

            nodes.forEach(node => {
                node.addEventListener('click', function() {
                    const targetId = this.getAttribute('data-target');
                    
                    // Remove all active states
                    nodes.forEach(n => n.classList.remove('active'));
                    panels.forEach(p => p.classList.remove('active'));
                    
                    // Activate the current node and panel
                    this.classList.add('active');
                    document.getElementById(targetId).classList.add('active');
                });
            });

            // Expand the first node by default
            if(nodes.length > 0) {
                nodes[0].click();
            }
        });
    </script>
